---
import "../style/global.css";
import Navbar from "../components/navbar.astro";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL, SITE_AUTHOR, SITE_IMAGE } from "../consts";

const {
    title,
    description,
    image,
    url,
    type = "website",
    author = SITE_AUTHOR,
} = Astro.props;

const siteTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
const siteDescription = description || SITE_DESCRIPTION;
const siteImage = image || SITE_IMAGE;
const siteUrl = url ? `${SITE_URL}/${url}` : SITE_URL;
---

<html lang="en" style="view-transition-name:root">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <meta name="generator" content={Astro.generator} />

        <title>{siteTitle}</title>
        <ClientRouter />
        <link rel="preload" as="image" href={siteImage} />
        <meta name="title" content={siteTitle} />
        <meta name="description" content={siteDescription} />
        <meta name="image" content={siteImage} />
        <meta name="author" content={author} />
        <meta name="robots" content="index, follow" />
        <link rel="canonical" href={siteUrl} />
        <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href={new URL("rss.xml", Astro.site)} />

        <meta property="og:type" content={type} />
        <meta property="og:url" content={siteUrl} />
        <meta property="og:title" content={siteTitle} />
        <meta property="og:description" content={siteDescription} />
        <meta property="og:image" content={siteImage} />
        <meta property="og:image:alt" content={siteDescription} />
        <meta property="og:site_name" content={SITE_TITLE} />
        <meta property="og:locale" content="en_US" />

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={siteUrl} />
        <meta property="twitter:title" content={siteTitle} />
        <meta property="twitter:description" content={siteDescription} />
        <meta property="twitter:image" content={siteImage} />
        <meta property="twitter:image:alt" content={siteDescription} />

        <meta name="theme-color" content="#000000" />
        <meta name="msapplication-TileColor" content="#000000" />
    </head>
    <body>
        <Font cssVariable="--font-geist-mono" preload />
        <div class="text-foreground mx-auto max-w-4xl px-4 py-8">
            <Navbar />
            <slot />
        </div>
    </body>
</html>
